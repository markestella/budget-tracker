generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  bio                String?
  password           String
  emailVerified      DateTime?
  image              String?
  preferredTheme     ThemePreference    @default(SYSTEM)
  preferredCurrency  String             @default("PHP")
  lastExportedAt     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accounts           Account[]
  customCategories   CustomCategory[]
  incomeRecords      IncomeRecord[]
  incomeSources      IncomeSource[]
  sessions           Session[]
  financialAccounts  FinancialAccount[]
  expenses           Expense[]
  budgets            Budget[]
  budgetItems        BudgetItem[]
  categoryBudgets    CategoryBudget[]
  notificationPreference NotificationPreference?
  pushSubscriptions  PushSubscription[]
  savingsGoals       SavingsGoal[]
  savingsTransactions SavingsTransaction[]
  gameProfile        GameProfile?
  xpTransactions     XPTransaction[]
  userBadges         UserBadge[]
  healthScoreHistory HealthScoreHistory[]
  userQuests         UserQuest[]
  streakFreezes      StreakFreeze[]
  userAvatar         UserAvatar?
  userAvatarItems    UserAvatarItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model IncomeSource {
  id            String           @id @default(cuid())
  userId        String
  name          String
  category      IncomeCategory
  description   String?
  frequency     PaymentFrequency
  amount        Decimal          @db.Decimal(10, 2)
  // Advanced scheduling fields
  scheduleDays       Int[]            @default([]) // For monthly: [15, 30] or [31] for last day, etc.
  scheduleWeekday    Int?             // For weekly/bi-weekly: 0=Sunday, 1=Monday, etc.
  scheduleWeek       ScheduleWeek?    // For bi-weekly: 'FIRST', 'SECOND', 'THIRD', 'FOURTH'
  scheduleTime       String?          // Time of day (HH:MM format)
  nextPaymentDate    DateTime?        // Auto-calculated next payment
  useManualAmounts   Boolean          @default(false) // Whether to use manual amounts per day
  scheduleDayAmounts Json?            // Manual amounts per day: {15: 30000, 30: 30000}
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  incomeRecords IncomeRecord[]
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("income_sources")
}

model IncomeRecord {
  id             String        @id @default(cuid())
  userId         String
  incomeSourceId String
  expectedDate   DateTime
  actualAmount   Decimal?      @db.Decimal(10, 2)
  actualDate     DateTime?
  status         PaymentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  incomeSource   IncomeSource  @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("income_records")
}

enum IncomeCategory {
  SALARY
  FREELANCE
  BUSINESS
  INVESTMENT
  RENTAL
  PENSION
  BENEFITS
  OTHER
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum PaymentStatus {
  PENDING
  RECEIVED
  OVERDUE
}

enum ScheduleWeek {
  FIRST
  SECOND
  THIRD
  FOURTH
  LAST
}

model FinancialAccount {
  id                  String                  @id @default(cuid())
  userId              String
  accountType         FinancialAccountType
  bankName            String
  accountName         String
  accountNumber       String?                 // Last 4 digits for display
  currentBalance      Decimal                 @db.Decimal(10,2)
  interestRate        Decimal?                @db.Decimal(5,4) // APY for savings, APR for credit
  status              AccountStatus           @default(ACTIVE)
  
  // Credit Card specific fields
  expiryDate          String?                 // MM/YY format
  cutoffDate          Int?                    // Day of month (1-31)
  statementDate       Int?                    // Auto-calculated: cutoff + 20 days
  creditLimit         Decimal?                @db.Decimal(10,2)
  minimumPaymentDue   Decimal?                @db.Decimal(10,2)
  paymentDueDate      DateTime?
  
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetItems         BudgetItem[]
  expenses            Expense[]

  @@map("financial_accounts")
}

model Expense {
  id                 String            @id @default(cuid())
  userId             String
  amount             Decimal           @db.Decimal(10,2)
  category           BudgetCategory
  merchant           String
  date               DateTime
  notes              String?
  linkedAccountId    String?
  isRecurring        Boolean           @default(false)
  linkedBudgetItemId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount      FinancialAccount? @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  linkedBudgetItem   BudgetItem?       @relation(fields: [linkedBudgetItemId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, category])
  @@index([linkedAccountId])
  @@index([linkedBudgetItemId])
  @@map("expenses")
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  name        String?
  totalAmount Decimal  @db.Decimal(10,2)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate, endDate])
  @@map("budgets")
}

model BudgetItem {
  id                String            @id @default(cuid())
  userId            String
  type              BudgetItemType
  description       String
  amount            Decimal           @db.Decimal(10,2)
  dueDate           Int
  merchant          String?
  category          BudgetCategory
  linkedAccountId   String?
  isActive          Boolean           @default(true)
  totalMonths       Int?
  startDate         DateTime?
  endDate           DateTime?
  completedPayments Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount     FinancialAccount? @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  expenses          Expense[]

  @@index([userId, type])
  @@index([userId, category])
  @@index([userId, isActive])
  @@index([linkedAccountId])
  @@map("budget_items")
}

model CategoryBudget {
  id           String         @id @default(cuid())
  userId       String
  category     BudgetCategory
  monthlyLimit Decimal        @db.Decimal(10,2)
  rollover     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("category_budgets")
}

model SavingsGoal {
  id                 String             @id @default(cuid())
  userId             String
  name               String
  institution        String
  type               SavingsGoalType
  monthlyContribution Decimal          @db.Decimal(10,2)
  currentBalance     Decimal            @db.Decimal(10,2)
  targetAmount       Decimal?           @db.Decimal(10,2)
  interestRate       Decimal?           @db.Decimal(5,4)
  startDate          DateTime
  lastUpdatedBalance DateTime
  status             SavingsGoalStatus  @default(ACTIVE)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       SavingsTransaction[]

  @@index([userId, status])
  @@index([userId, type])
  @@map("savings_goals")
}

model SavingsTransaction {
  id            String                 @id @default(cuid())
  userId        String
  savingsGoalId String
  amount        Decimal                @db.Decimal(10,2)
  type          SavingsTransactionType
  date          DateTime
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal   SavingsGoal            @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([savingsGoalId, date])
  @@map("savings_transactions")
}

model CustomCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("custom_categories")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  billReminders      Boolean  @default(true)
  budgetWarnings     Boolean  @default(true)
  achievementAlerts  Boolean  @default(true)
  dailyTips          Boolean  @default(false)
  weeklySummary      Boolean  @default(true)
  streakWarnings     Boolean  @default(true)
  challengeDeadlines Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

enum FinancialAccountType {
  SAVINGS
  CHECKING
  CREDIT_CARD
  DEBIT_CARD
}

enum BudgetItemType {
  CONSTANT
  DURATION
}

enum BudgetCategory {
  HOUSING
  TRANSPORTATION
  FOOD_DINING
  UTILITIES
  ENTERTAINMENT
  HEALTHCARE
  SAVINGS_ALLOCATION
  DEBT_PAYMENTS
  MISCELLANEOUS
  CUSTOM
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum SavingsGoalType {
  EMERGENCY_FUND
  RETIREMENT
  VACATION
  EDUCATION
  INVESTMENT
  GENERAL
}

enum SavingsGoalStatus {
  ACTIVE
  IDLE
  WITHDRAWN
}

enum SavingsTransactionType {
  DEPOSIT
  WITHDRAWAL
  INTEREST
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

// ─── Gamification Models ─────────────────────────────────────────────

model GameProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  xp                   Int       @default(0)
  level                Int       @default(1)
  currentStreak        Int       @default(0)
  longestStreak        Int       @default(0)
  lastActiveDate       DateTime?
  totalBadges          Int       @default(0)
  financialHealthScore Int       @default(0)
  moneyPersonality     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("game_profiles")
}

model XPTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  action      String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

model Badge {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String
  icon        String
  category    BadgeCategory
  tier        BadgeTier
  xpReward    Int
  createdAt   DateTime      @default(now())
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  earnedAt    DateTime @default(now())
  isShowcased Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model HealthScoreHistory {
  id               String   @id @default(cuid())
  userId           String
  score            Int
  tier             String
  budgetScore      Int
  savingsScore     Int
  emergencyScore   Int
  debtScore        Int
  consistencyScore Int
  calculatedAt     DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, calculatedAt])
  @@map("health_score_history")
}

model QuestDefinition {
  id          String    @id @default(cuid())
  title       String
  description String
  type        QuestType
  xpReward    Int
  category    String
  conditions  Json
  isActive    Boolean   @default(true)
  userQuests  UserQuest[]

  @@map("quest_definitions")
}

model UserQuest {
  id                String           @id @default(cuid())
  userId            String
  questDefinitionId String
  assignedAt        DateTime         @default(now())
  expiresAt         DateTime
  progress          Int              @default(0)
  status            QuestStatus      @default(ACTIVE)
  completedAt       DateTime?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  questDefinition   QuestDefinition  @relation(fields: [questDefinitionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, expiresAt])
  @@map("user_quests")
}

model StreakFreeze {
  id     String   @id @default(cuid())
  userId String
  usedAt DateTime @default(now())
  weekOf DateTime
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekOf])
  @@map("streak_freezes")
}

model AvatarItem {
  id              String              @id @default(cuid())
  name            String
  type            AvatarItemType
  unlockCondition AvatarUnlockCondition
  unlockValue     String?
  imageUrl        String
  createdAt       DateTime            @default(now())
  userAvatarItems UserAvatarItem[]

  @@map("avatar_items")
}

model UserAvatar {
  id           String  @id @default(cuid())
  userId       String  @unique
  baseId       String
  hatId        String?
  backgroundId String?
  frameId      String?
  accessoryId  String?
  title        String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_avatars")
}

model UserAvatarItem {
  id           String     @id @default(cuid())
  userId       String
  avatarItemId String
  unlockedAt   DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarItem   AvatarItem @relation(fields: [avatarItemId], references: [id], onDelete: Cascade)

  @@unique([userId, avatarItemId])
  @@index([userId])
  @@map("user_avatar_items")
}

enum BadgeCategory {
  STARTER
  SAVINGS
  DISCIPLINE
  BUDGET
  MILESTONE
  SPECIAL
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum QuestType {
  DAILY
  WEEKLY
  MONTHLY
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum AvatarItemType {
  BASE
  HAT
  BACKGROUND
  FRAME
  ACCESSORY
}

enum AvatarUnlockCondition {
  LEVEL
  BADGE
  PREMIUM
  FREE
}
