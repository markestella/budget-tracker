{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build:vercel",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/notifications?job=daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/notifications?job=weekly",
      "schedule": "0 9 * * 0"
    }
  ]
}